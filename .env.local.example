# Copy to .env.local and fill in. NEXT_PUBLIC_ vars are inlined at build time.

# Google Apps Script Web App URL that appends form/chat submissions to your
# Google Sheet. Deploy google-apps-script/Code.gs as a Web App and paste the
# /exec URL here. If left empty, the site still works — submissions are logged
# to the browser console instead of being sent anywhere.
NEXT_PUBLIC_SHEETS_ENDPOINT=
